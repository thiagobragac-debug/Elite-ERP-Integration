# EditorConfig: https://EditorConfig.org
root = true

# Padrões para todos os arquivos
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown preserva trailing whitespace (quebras de linha)
[*.md]
trim_trailing_whitespace = false

# JSON, YAML e config files
[*.{json,yml,yaml}]
indent_size = 2

# TypeScript, JavaScript e React
[*.{ts,tsx,js,jsx}]
indent_size = 2
quote_type = single

# HTML
[*.html]
indent_size = 2

# CSS e SCSS
[*.{css,scss}]
indent_size = 2

# Shell scripts
[*.{sh,bash}]
indent_size = 2
end_of_line = lf

# Package files (não editar manualmente)
[{package.json,package-lock.json}]
indent_size = 2
