# Tauze ERP v5.0 - Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# REQUIRED - Supabase Configuration
# ============================================
# Your Supabase project URL
# Get from: Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon/public key
# Get from: Supabase Dashboard → Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# OPTIONAL - Payment & Monitoring
# ============================================
# Stripe publishable key (for billing/payments)
# Get from: Stripe Dashboard → Developers → API keys → Publishable key
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Sentry DSN (for error tracking)
# Get from: Sentry Dashboard → Settings → Projects → [Your Project] → Client Keys (DSN)
# VITE_SENTRY_DSN=https://...

# PostHog API key (for analytics)
# Get from: PostHog Dashboard → Project Settings → Project API Key
# VITE_POSTHOG_KEY=phc_...

# ============================================
# OPTIONAL - E2E Testing
# ============================================
# E2E Test Credentials
# Create a dedicated test user in your Supabase project for automated testing
# E2E_TEST_EMAIL=test@example.com
# E2E_TEST_PASSWORD=test123456

# ============================================
# STAGING DEPLOYMENT - GitHub Actions Secrets
# ============================================
# These variables are used for staging deployment on the 'develop' branch
# Configure these as GitHub repository secrets:
# Repository → Settings → Secrets and variables → Actions → New repository secret
#
# Vercel Deployment:
# - VERCEL_TOKEN (from Vercel Dashboard → Account → Tokens)
# - VERCEL_ORG_ID (from .vercel/project.json after running 'vercel link')
# - VERCEL_PROJECT_ID (from .vercel/project.json)
#
# Staging Environment Variables:
# - STAGING_SUPABASE_URL (staging Supabase project URL)
# - STAGING_SUPABASE_ANON_KEY (staging Supabase anon key)
# - STAGING_STRIPE_PUBLISHABLE_KEY (Stripe test mode key: pk_test_...)
# - STAGING_SENTRY_DSN (staging Sentry project DSN)
# - STAGING_POSTHOG_KEY (staging PostHog project key)
# - STAGING_POSTHOG_HOST (https://app.posthog.com)
#
# Notifications:
# - SLACK_WEBHOOK_URL (from Slack → Apps → Incoming Webhooks)
#
# See: STAGING_DEPLOYMENT_CHECKLIST.md for setup instructions
